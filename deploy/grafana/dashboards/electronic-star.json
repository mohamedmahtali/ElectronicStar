{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Electronic-Star — Ops",
  "uid": "electronic-star-ops",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API — Requêtes / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total[1m])) * 60",
          "legendFormat": "req/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "API — Latence p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_highr_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "API — Taux d'erreurs 5xx (%)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Crawler — Items ingérés par marchand",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crawl_items_scraped_total",
          "legendFormat": "{{ merchant }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 5,
      "title": "Crawler — Durée du crawl (s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crawl_duration_seconds",
          "legendFormat": "{{ merchant }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Crawler — Ratio succès (%)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crawl_success_ratio * 100",
          "legendFormat": "{{ merchant }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Crawler — CAPTCHAs détectés",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(crawl_captcha_total)",
          "legendFormat": "CAPTCHAs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Crawler — Pages bloquées (403/429)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(crawl_blocked_total)",
          "legendFormat": "Bloquées"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    }
  ]
}
